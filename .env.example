# Zorvyn Finance Dashboard - Environment configuration
# Copy this file to .env and fill in the values below

# Port for the express server
PORT=3000

# MongoDB Connection URI (e.g., mongodb+srv://user:pass@cluster.mongodb.net/dbname)
MONGO_URI=your_mongodb_connection_uri_here

# Secret key for JWT signing (any long random string)
JWT_SECRET=your_random_jwt_secret_here

# JWT Expiry details (e.g., 7d, 24h)
JWT_EXPIRES_IN=24h

# Email Configuration (for future notifications / logging)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password_here
